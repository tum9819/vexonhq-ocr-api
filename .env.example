# Copy ไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# ห้าม commit ไฟล์ .env ขึ้น GitHub!
# ค่าจริงทั้งหมดอยู่ใน Coolify → vexonhq-ocr-api → Environment Variables

# ── Database / Supabase (required) ──────────────────────────────
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<service-role-jwt>
SUPABASE_STORAGE_BUCKET=uploads

# ── Auth (required) ─────────────────────────────────────────────
JWT_SECRET=<strong-random-secret>
VEXON_USER=<login-username>
VEXON_HASH=<pbkdf2-password-hash>
VEXON_ADMINS=tum,vexonhq
SUPABASE_JWT_SECRET=<supabase-legacy-hs256-secret>

# ── OpenAI (required for OCR/AI features) ───────────────────────
OPENAI_API_KEY=sk-...
OPENAI_VISION_MODEL=gpt-4o
OPENAI_CATEGORIZE_MODEL=
OPENAI_SEARCH_MODEL=
OPENAI_LINE_IMAGE_MODEL=
PRODUCT_CLASSIFIER_MODEL=
OCR_STRUCTURED=

# ── Anthropic (optional — AI auto-diagnosis) ────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_VERSION=
ANTHROPIC_DIAGNOSE_MODEL=
ANTHROPIC_HAIKU_MODEL=
ANTHROPIC_VISION_MODEL=

# ── LINE bot (required for digests/webhook) ─────────────────────
LINE_CHANNEL_TOKEN=
LINE_CHANNEL_SECRET=
LINE_USER_ID=

# ── Alerts: Discord / Telegram (optional) ───────────────────────
DISCORD_BOT_TOKEN=
DISCORD_APP_ID=
DISCORD_APP_PUBLIC_KEY=
DISCORD_OPS_CHANNEL_ID=
DISCORD_OPS_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERTS_WEBHOOK_SECRET=<strong-random-secret>

# ── Ops: Coolify / DigitalOcean snapshots (optional) ────────────
COOLIFY_API_TOKEN=
COOLIFY_BACKEND_APP_UUID=
COOLIFY_LOG_TAIL_LINES=
DO_API_TOKEN=
DO_DROPLET_NAME=
DO_SNAPSHOT_PREFIX=
DO_SNAPSHOT_MAX_KEEP=

# ── Monitoring / misc (optional) ────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=
SLOW_QUERY_WARN_SEC=
SLOW_QUERY_CRITICAL_SEC=
LOG_FORMAT=
WEB_CONCURRENCY=
USD_THB=
AI_PRICES_JSON=
AI_DRIFT_ALERTS_ARMED=
AI_EXEC_SECRET=
AI_EXEC_ALLOWED_IPS=
POS_FRESHNESS_STALE_DAYS=
