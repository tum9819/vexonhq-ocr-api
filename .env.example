# Copy ไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# ห้าม commit ไฟล์ .env ขึ้น GitHub!

# Copy จาก Coolify → vexonhq-ocr-api → Environment Variables → DATABASE_URL
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# --- Staging & Safety Guardrails ---
# CORS_ALLOW_ORIGINS: Comma-separated list of allowed origins.
# If empty, defaults to production origins (app.marastation.com, etc.).
# For staging, set this to the staging frontend URL (e.g. https://staging-uuid.sslip.io).
# Wildcard '*' is blocked.
CORS_ALLOW_ORIGINS=

# ENABLE_SCHEDULER: Set to "true" to enable background cron jobs (LINE digests, etc.).
# MUST be set to "true" on Production! Defaults to disabled (safe for staging/local).
ENABLE_SCHEDULER=true

# Note for Staging:
# Do NOT set LINE_CHANNEL_ACCESS_TOKEN, LINE_CHANNEL_SECRET,
# DISCORD_BOT_TOKEN, DISCORD_OPS_WEBHOOK_URL, or TELEGRAM_BOT_TOKEN 
# in the staging environment to prevent side-effects.
